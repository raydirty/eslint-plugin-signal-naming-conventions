{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": ".",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "types": ["node", "vitest/globals"]
  },
  "include": ["tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
